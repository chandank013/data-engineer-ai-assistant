# AI Data Engineer Assistant — .env configuration

# ── Groq LLM ──
GROQ_API_KEY=api_key_here
# Get key at: https://console.groq.com
GROQ_MODEL=select the appropriate model for your use case (e.g., groq-1, groq-2, etc.)

# ── Flask ──
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# SPARK / HADOOP CONFIGURATION

# ── Local mode (default, no cluster needed) ──
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SHUFFLE_PARTITIONS=4
SPARK_APP_NAME=AIDataEngineerAssistant

# ── Hadoop YARN cluster ──
# Uncomment and fill these to use a real Hadoop cluster:
# SPARK_MASTER=yarn
# HDFS_NAMENODE=hdfs://namenode:9000
# YARN_RESOURCE_MANAGER=resourcemanager:8032
# SPARK_DRIVER_MEMORY=4g
# SPARK_EXECUTOR_MEMORY=4g
# SPARK_EXECUTOR_CORES=2
# SPARK_NUM_EXECUTORS=4

# ── Standalone Spark cluster ──
# SPARK_MASTER=spark://master-host:7077

# ── Hive metastore (optional) ──
SPARK_ENABLE_HIVE=true

# EMBEDDING MODEL
EMBEDDING_MODEL=take appropriate embedding model (e.g., text-embedding-3-small)